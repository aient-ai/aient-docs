{
  "$schema": "https://mintlify.com/docs.json",
  "appearance": {
    "default": "system"
  },
  "background": {
    "color": {
      "dark": "#0E0F11",
      "light": "#F4F4F0"
    }
  },
  "colors": {
    "dark": "#4ADE80",
    "light": "#00A878",
    "primary": "#0A7A45"
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "mcp"
    ]
  },
  "description": "Aient integration docs for the CLI, telemetry, source maps, webhooks, and event schemas.",
  "favicon": {
    "dark": "/logo/aient-favicon-dark.svg",
    "light": "/logo/aient-favicon-light.svg"
  },
  "fonts": {
    "body": {
      "family": "DM Sans",
      "weight": 300
    },
    "family": "DM Sans",
    "heading": {
      "family": "Instrument Serif",
      "weight": 400
    },
    "weight": 300
  },
  "footer": {
    "socials": {
      "github": "https://github.com/haf/glimt"
    }
  },
  "icons": {
    "library": "lucide"
  },
  "logo": {
    "dark": "/logo/aient-lockup-dark.svg",
    "href": "https://aient.ai",
    "light": "/logo/aient-lockup-light.svg"
  },
  "name": "Aient",
  "navbar": {
    "links": [
      {
        "href": "https://www.npmjs.com/package/@aient/otel",
        "label": "npm: @aient/otel"
      },
      {
        "href": "https://www.npmjs.com/package/@aient/otel-browser",
        "label": "npm: @aient/otel-browser"
      },
      {
        "href": "https://www.npmjs.com/package/@aient/sourcemaps",
        "label": "npm: @aient/sourcemaps"
      }
    ]
  },
  "navigation": {
    "groups": [
      {
        "group": "Start",
        "icon": "play",
        "pages": [
          "quickstart/server",
          "quickstart/browser",
          "vercel/drain",
          "aws/firehose",
          "source-maps/upload",
          "questions"
        ],
        "root": "index"
      },
      {
        "group": "Webhooks",
        "icon": "webhook",
        "pages": [
          "webhooks/signing",
          {
            "group": "Event Schemas",
            "icon": "braces",
            "pages": [
              "webhooks/events/index",
              "webhooks/events/ai.aient.instrumentation.discovery_started",
              "webhooks/events/ai.aient.instrumentation.pr_merged",
              "webhooks/events/ai.aient.instrumentation.services_selected",
              "webhooks/events/ai.aient.integration.github.connected",
              "webhooks/events/ai.aient.integration.github.disconnected",
              "webhooks/events/ai.aient.integration.linear.connected",
              "webhooks/events/ai.aient.integration.linear.disconnected",
              "webhooks/events/ai.aient.integration.mcp.connected",
              "webhooks/events/ai.aient.integration.scm.connected",
              "webhooks/events/ai.aient.integration.scm.disconnected",
              "webhooks/events/ai.aient.integration.slack.connected",
              "webhooks/events/ai.aient.integration.slack.disconnected",
              "webhooks/events/ai.aient.integration.slack.notification_channel_selected",
              "webhooks/events/ai.aient.onboarding.completed",
              "webhooks/events/ai.aient.organisation.created",
              "webhooks/events/ai.aient.problem.closed",
              "webhooks/events/ai.aient.problem.detected",
              "webhooks/events/ai.aient.problem.duplicate_changed",
              "webhooks/events/ai.aient.problem.regressed",
              "webhooks/events/ai.aient.problem.remediation_decision_recorded",
              "webhooks/events/ai.aient.problem.reopened",
              "webhooks/events/ai.aient.problem.suppression_changed",
              "webhooks/events/ai.aient.problem.triaged",
              "webhooks/events/ai.aient.problem.verification_started",
              "webhooks/events/ai.aient.remediation.investigation_completed",
              "webhooks/events/ai.aient.remediation.pr_created",
              "webhooks/events/ai.aient.remediation.verified",
              "webhooks/events/ai.aient.repository.discovered",
              "webhooks/events/ai.aient.team.invitation_accepted",
              "webhooks/events/ai.aient.telemetry.received"
            ]
          }
        ],
        "root": "webhooks/overview"
      },
      {
        "group": "Reference",
        "icon": "book-open",
        "pages": [
          "reference/otlp-endpoints",
          "reference/sdk-server",
          "reference/sdk-browser",
          "reference/sourcemaps-cli",
          "reference/event-registry"
        ]
      },
      {
        "group": "AI Tools",
        "icon": "bot",
        "pages": [
          "ai-tools/cli",
          "agentic-x402",
          "agent-commerce"
        ],
        "root": "ai-tools"
      },
      {
        "group": "Changelog",
        "icon": "rss",
        "pages": [
          "changelog"
        ]
      }
    ]
  },
  "styling": {
    "codeblocks": {
      "theme": {
        "dark": "github-dark",
        "light": "github-light"
      }
    },
    "eyebrows": "breadcrumbs"
  },
  "theme": "mint"
}
